{
  "name": "supabase-functions",
  "version": "1.0.0",
  "description": "Deno test runner for Supabase Edge Functions",
  "private": true,
  "devDependencies": {
    "deno": "^1.46.0"
  },
  "scripts": {
    "test:coverage": "deno test --coverage=coverage --no-check --allow-all api/index_test.ts _shared/shared_helpers_test.ts _shared/auth_test.ts",
    "coverage:lcov": "deno coverage coverage --lcov > coverage/lcov.info"
  }
}
