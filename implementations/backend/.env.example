# Backend Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql+psycopg2://postgres.your-project-ref:your-password@aws-0-xx.pooler.supabase.com:6543/postgres

# Authentication
JWT_SECRET=your-jwt-secret-here

# Environment
ENVIRONMENT=production

# CORS - comma-separated list of allowed origins
CORS_ORIGINS=https://your-frontend.vercel.app,https://your-android-app.firebaseapp.com
