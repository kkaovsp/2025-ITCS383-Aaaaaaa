# Database URL (default uses SQLite for local development)
DATABASE_URL=sqlite+aiosqlite:///./booth_system.db

# JWT settings
JWT_SECRET=your_secret_key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_SECONDS=3600

# Mock MOI API URL (not used in this simple implementation)
MOI_API_URL=https://api.moi.gov/verify
